        <remapping>odom:=odom</remapping>
      </ros>

      <num_wheel_pairs>2</num_wheel_pairs>
      <left_joint>lwheel1_Joint</left_joint>
      <left_joint>lwheel2_Joint</left_joint>
      <right_joint>rwheel1_Joint</right_joint>
      <right_joint>rwheel2_Joint</right_joint>

      <wheel_separation>0.1955</wheel_separation>
