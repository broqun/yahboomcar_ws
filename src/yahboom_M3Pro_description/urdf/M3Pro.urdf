    <sensor name="dabai_dcw2" type="depth">
      <always_on>true</always_on>
      <update_rate>30.0</update_rate>
      <camera name="dcw2_lens">
        <horizontal_fov>${pi/2}</horizontal_fov>
        <image>
          <width>1280</width>
          <height>720</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.1</near>
          <far>10.0</far>
        </clip>
      </camera>

      <plugin name="dcw2_driver" filename="libgazebo_ros_camera.so">
        <!-- <ros>
          <namespace>dabai_dcw2</namespace>
        </ros> -->
        <frame_name>camera_optical_link</frame_name>
        <min_depth>0.1</min_depth>
        <max_depth>10.0</max_depth>
      </plugin>
    </sensor>
  </gazebo>

  <gazebo reference="Camera">
    <material>Gazebo/DarkGrey</material>
  </gazebo>
  <gazebo>
    <!-- <plugin name="m3pro_diff_drive" filename="libgazebo_ros_diff_drive.so">
