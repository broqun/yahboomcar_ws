    Help Height: 70
    Name: Displays
    Property Tree Widget:
      Expanded:
        - /Global Options1
        - /TF1
        - /TF1/Frames1
        - /Image1
        - /LaserScan1
        - /LaserScan1/Topic1
        - /Map1
        - /Map1/Topic1
      Splitter Ratio: 0.5
    Tree Height: 349
  - Class: rviz_common/Views
    Expanded:
      - /Current View1
    Name: Views
    Splitter Ratio: 0.5
